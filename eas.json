{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "ALLOW_TEST_BYPASS": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "ALLOW_TEST_BYPASS": "1"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true
    },
    "testflight": {
      "distribution": "store",
      "autoIncrement": true
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true
    }
  },
  "submit": {
    "testflight": {
      "ios": {
        "appleId": "bethcontab@gmail.com",
        "ascAppId": "6751608029",
        "appleTeamId": "VUZ53GK36M"
      }
    },
    "production": {
      "ios": {
        "appleId": "bethcontab@gmail.com",
        "ascAppId": "6751608029",
        "appleTeamId": "VUZ53GK36M"
      }
    }
  }
}
